{
  "name": "sleeplab",
  "version": "1.4.9",
  "private": true,
  "scripts": {
    "api": "nx serve api",
    "frontend": "nx serve frontend",
    "dev": "nx run-many --target=serve --projects=api,frontend --parallel",
    "build": "nx build frontend",
    "docs-capture": "nx run frontend:capture:ci",
    "storybook-capture": "nx run frontend:build-storybook && nx run frontend:capture:stories:ci",
    "storybook-capture:no-build": "nx run frontend:capture:stories:ci",
    "docs:build": "npm run docs:frontend && uv run mkdocs build",
    "docs:serve": "npm run docs:frontend && uv run mkdocs serve",
    "docs:frontend": "cd frontend && npx typedoc",
    "lint": "nx lint frontend",
    "test": "nx run-many --target=test --projects=api,frontend",
    "test:frontend": "nx test frontend",
    "typecheck": "nx typecheck frontend",
    "check:workspace-lockfile": "node scripts/check-workspace-lockfile.mjs"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.1.1",
    "@rollup/rollup-linux-x64-gnu": "4.61.1",
    "@tailwindcss/oxide-linux-x64-gnu": "4.3.0",
    "lightningcss-linux-x64-gnu": "1.32.0"
  },
  "devDependencies": {
    "@nx/js": "22.7.5",
    "@nx/react": "^23.1.0",
    "@nx/storybook": "^22.7.5",
    "@nx/web": "22.7.5",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@storybook/addon-vitest": "^10.4.2",
    "@storybook/react-vite": "10.4.6",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.7",
    "nx": "^22.7.5",
    "prettier": "~3.8.4",
    "semantic-release": "^25.0.8",
    "storybook": "10.4.6",
    "ts-node": "10.9.2",
    "typescript": "~6.0.3",
    "vite": "^8.0.0"
  },
  "workspaces": [
    "frontend"
  ]
}
