# FastAPI auth
SECRET_KEY=replace-me-with-a-long-random-secret

# Optional: enables AI summary endpoints
OPENAI_API_KEY=

# PostgreSQL
# Local macOS/Homebrew-style setup:
DATABASE_URL=postgresql+psycopg2://localhost/cpap

# Frontend API base URL
VITE_API_URL=http://127.0.0.1:8000

# Self-hosted deployment
CORS_ALLOWED_ORIGINS=*
API_URL=http://localhost:8000
API_HOST=0.0.0.0
API_PORT=8000
